+    if (landmark_count > 0) {
+        landmark_dist.assign(size_t(V) * landmark_count, INF32);
+        for (int32_t i = 0; i < landmark_count; ++i) {
+            const int64_t* row = tmp.data() + size_t(i) * V;
+            for (int32_t v = 0; v < V; ++v)
