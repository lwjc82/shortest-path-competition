+static int64_t cluster_component_dijkstra(int32_t s, int32_t t, int32_t comp) {
+    if (s == t) return 0;
+    const int32_t stamp = next_stamp();
+    heap_f.clear();
+    set_dist(dist_f, seen_f, s, stamp, 0);
+    heap_f.push({0, 0, s});
+    while (!heap_f.empty()) {
+        HeapItem item = heap_f.pop();
+        int64_t cur_dist = get_dist(dist_f, seen_f, item.v, stamp);
+        if (item.dist != cur_dist) continue;
+        if (item.v == t) return item.dist;
+        for (int32_t ei = offset[item.v]; ei < offset[item.v + 1]; ++ei) {
+            int32_t v = adj_to[ei];
+            if (cluster_comp_id[v] != comp) continue;
+            int32_t gap = item.v >= v ? item.v - v : v - item.v;
+            if (gap > CLUSTER_LOCAL_GAP) continue;
+            int64_t nd = item.dist + adj_w[ei];
+            if (nd < get_dist(dist_f, seen_f, v, stamp)) {
+                set_dist(dist_f, seen_f, v, stamp, nd);
+                heap_f.push({nd, nd, v});
+            }
+        }
+    }
+    return INF;
+}
