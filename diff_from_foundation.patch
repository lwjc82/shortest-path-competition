+static vector<int64_t> full_dijkstra(int32_t source) {
+    vector<int64_t> d(V, INF); radix_a.clear(); d[source] = 0; radix_a.push({0, 0, source});
+    while (!radix_a.empty()) {
+        auto item = radix_a.pop(); if (item.dist != d[item.v]) continue;
