+static void build_landmarks(int32_t req) {
+    if (req <= 0 || V <= 0) return;
+    req = std::min(req, V);
+    vector<int64_t> tmp; tmp.reserve(size_t(req) * V);
+    vector<int64_t> best(V, INF); vector<char> chosen(V, 0); int32_t cur = 0;
+    for (int32_t i = 0; i < req; ++i) {
+        while (cur < V && chosen[cur]) ++cur;
+        if (cur >= V) break;
+        chosen[cur] = 1; auto d = full_dijkstra(cur);
+        tmp.insert(tmp.end(), d.begin(), d.end()); ++landmark_count;
+        int32_t next = -1; int64_t best_s = -1;
+        for (int32_t v = 0; v < V; ++v) {
+            if (d[v] < best[v]) best[v] = d[v];
+            if (!chosen[v] && best[v] != INF && best[v] > best_s) { best_s = best[v]; next = v; }
+        }
+        if (next < 0) {
+            for (int32_t v = 0; v < V; ++v) {
+                if (!chosen[v]) { next = v; break; }
+            }
+        }
+        if (next < 0) break;
+        cur = next;
